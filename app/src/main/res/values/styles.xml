<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="CustomButtonPrimary" parent="Widget.Material3.Button">
        <item name="android:layout_width">@dimen/button_width</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="cornerRadius">@dimen/corner_radius</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CustomButtonSecondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">@dimen/button_width</item>
        <item name="android:layout_height">@dimen/button_height</item>
        <item name="android:textColor">@color/button_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="cornerRadius">@dimen/corner_radius</item>
        <item name="strokeColor">@color/button_secondary</item>
        <item name="strokeWidth">2dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CustomTextTitle" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_title</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CustomTextSubtitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_subtitle</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="CustomTextBody" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="CustomMemberButton" parent="Widget.Material3.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:backgroundTint">@color/white_button</item>
        <item name="android:textColor">@color/white_button_text</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:gravity">center</item>
        <item name="android:textAlignment">center</item>
        <item name="cornerRadius">@dimen/corner_radius</item>
    </style>

    <style name="CustomCardView" parent="Widget.Material3.CardView.Filled">
        <item name="android:layout_margin">@dimen/margin_medium</item>
        <item name="cardCornerRadius">@dimen/corner_radius</item>
        <item name="cardElevation">@dimen/card_elevation</item>
        <item name="contentPadding">@dimen/padding_large</item>
    </style>

    <style name="CustomTextLabel" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">@dimen/text_size_body</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="CircleImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">40dp</item>
    </style>
</resources>
